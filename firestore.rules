rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Administrative user verification
    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == 'contatorobertgomes@gmail.com' ||
          request.auth.token.email.lower() == 'admin@rdparfums.com'
        );
    }

    // Standard type validation for perfume entities
    function isValidPerfume(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && data.category is string && (data.category == 'MASCULINO' || data.category == 'FEMININO')
          && data.family is string && data.family.size() <= 200
          && data.image is string && data.image.size() <= 1000
          && data.description is string && data.description.size() <= 2000
          && data.intensity is string && (data.intensity == 'Suave' || data.intensity == 'Moderado' || data.intensity == 'Intenso')
          && data.topNotes is list && data.topNotes.size() <= 10
          && data.heartNotes is list && data.heartNotes.size() <= 10
          && data.baseNotes is list && data.baseNotes.size() <= 10
          && data.volumeAvailable is list && data.volumeAvailable.size() <= 10;
    }

    // Rules for perfumes path
    match /perfumes/{perfumeId} {
      // Catalog browsing is fully public (anyone can view products)
      allow read, get, list: if true;
      
      // Catalog updates and deletions are restricted exclusively to administrators
      allow create: if isAdmin() && isValidPerfume(request.resource.data);
      allow update: if isAdmin() && isValidPerfume(request.resource.data);
      allow delete: if isAdmin();
    }

    // ============ COUPON RULES ============
    
    // Validate coupon structure
    function isValidCoupon(data) {
      return data.code is string && data.code.size() > 0 && data.code.size() <= 50
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.discountType is string && (data.discountType == 'fixed' || data.discountType == 'percentage')
          && data.discountValue is number && data.discountValue > 0
          && data.maxUses is number && data.maxUses > 0
          && data.usesPerPerson is number && data.usesPerPerson > 0
          && data.currentUses is number && data.currentUses >= 0
          && data.validFrom is string
          && data.validUntil is string
          && data.isActive is bool;
    }

    // Coupons collection - admin only for write, public read
    match /coupons/{couponId} {
      // Guests can read active coupons (to validate)
      allow read: if resource.data.isActive == true;
      
      // Only admins can create, update, delete
      allow create: if isAdmin() && isValidCoupon(request.resource.data);
      allow update: if isAdmin() && isValidCoupon(request.resource.data);
      allow delete: if isAdmin();
    }

    // Coupon usage tracking - write only, admin can read
    match /coupon_usage/{usageId} {
      // Only admins can read usage history
      allow read: if isAdmin();
      
      // Anyone can record a coupon usage (will be validated by backend)
      allow create: if request.resource.data.couponId is string
                     && request.resource.data.whatsappNumber is string
                     && request.resource.data.discountApplied is number
                     && request.resource.data.orderTotal is number
                     && request.resource.data.usedAt is string;
      
      allow update, delete: if isAdmin();
    }
  }
}

